# ---- Kinde Auth ---- (https://kinde.com)
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
KINDE_ISSUER_URL=https://YOUR_SUBDOMAIN.kinde.com
KINDE_SITE_URL=http://localhost:3000
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3000
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3000/auth-callback

# ---- Database ---- Neon Postgres with the pgvector extension (https://neon.tech)
# Pooled connection string used at runtime
DATABASE_URL=
# Direct (non-pooled) connection string used by Prisma migrations
DIRECT_URL=

# ---- File uploads ---- UploadThing (https://uploadthing.com)
UPLOADTHING_TOKEN=

# ---- Embeddings ---- Voyage AI (https://voyageai.com)
VOYAGE_API_KEY=

# ---- LLM ---- Anthropic / Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# App URL (used for absolute links; auto-set on Vercel)
# VERCEL_URL is provided automatically by Vercel in production.
